# Dashboard password
PASSWORD=jessie123

APP_PORT=9000
LSP_PORT=9001

# Database
# Nếu dùng docker-compose: POSTGRES_HOST=postgres, REDIS_HOST=redis
# Nếu chạy local: POSTGRES_HOST=localhost, REDIS_HOST=localhost
POSTGRES_HOST=postgres
POSTGRES_NAME=jesse_db
POSTGRES_PORT=5432
POSTGRES_USERNAME=jesse_user
POSTGRES_PASSWORD=password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Jesse live plugin license token
LICENSE_API_TOKEN=

# Optional placeholders for later live/testnet setup.
# Keep them here so credentials can be filled in later if you want to track
# them through the local env file, even if the live plugin asks them in UI.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
